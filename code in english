contact_mat<- matrix(
  c(18,5,1, # 0–17 -> 0–17, 18–64, 65+
    4,6,2, # 18–64 -> 0–17, 18–64, 65+
    1,2,2  # 65+ -> 0–17, 18–64, 65+
